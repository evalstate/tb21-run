# Checkout containing Harbor's built-in fast-agent adapter (PR #2365 or newer).
HARBOR_ROOT=/home/ssmith/temp/harbor

# Optional overrides.
TB21_JOBS_DIR=/home/ssmith/source/tb21-run/jobs
